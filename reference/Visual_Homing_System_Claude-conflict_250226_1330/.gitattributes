# Normalize line endings for cross-platform consistency.
# Shell scripts MUST use LF — CRLF breaks bash on Linux/Pi.

# Default: auto-detect text, normalize to LF in repo
* text=auto eol=lf

# Shell scripts: always LF (critical for Pi/Linux execution)
*.sh text eol=lf

# Python: LF
*.py text eol=lf

# Web/config: LF
*.js   text eol=lf
*.ts   text eol=lf
*.jsx  text eol=lf
*.tsx  text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.txt  text eol=lf
*.conf text eol=lf
*.param text eol=lf
*.service text eol=lf

# Gradle wrapper (must be LF on Unix, but Windows needs CRLF)
gradlew   text eol=lf
gradlew.bat text eol=crlf

# Binary files: no line ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.so   binary
*.a    binary
*.o    binary
